FROM docker.io/cachyos/cachyos-v3:latest

ARG BASE_OPT_TIMEZONE
ARG BASE_OPT_KEYMAP
ARG BASE_OPT_LANGUAGE

RUN pacman-key --init && pacman-key --populate archlinux cachyos && \
    pacman --noconfirm -Syy && \
    ln -sf /usr/share/zoneinfo/${BASE_OPT_TIMEZONE} /etc/localtime && \
    echo "KEYMAP=${BASE_OPT_KEYMAP}" > /etc/vconsole.conf && \
    echo "LANG=${BASE_OPT_LANGUAGE}.UTF-8" > /etc/locale.conf && \
    echo "${BASE_OPT_LANGUAGE}.UTF-8 UTF-8" > /etc/locale.gen && \
    locale-gen && \
    mkdir -p /etc/mkinitcpio.conf.d && \
    echo "HOOKS=(base systemd ostree autodetect modconf kms keyboard sd-vconsole block filesystems fsck)" \
        > /etc/mkinitcpio.conf.d/ostree.conf && \
    echo "options overlay metacopy=off redirect_dir=off" \
        > /etc/modprobe.d/disable-overlay-redirect-dir.conf && \
    echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf && \
    pacman --noconfirm --needed -S polkit networkmanager && \
    systemctl enable NetworkManager.service && \
    systemctl enable systemd-resolved.service && \
    systemctl mask systemd-networkd-wait-online.service && \
    pacman --noconfirm --needed -Syuu \
        linux-cachyos linux-cachyos-headers linux-firmware \
        sof-firmware alsa-firmware alsa-ucm-conf \
        amd-ucode intel-ucode \
        dosfstools xfsprogs \
        grub mkinitcpio efibootmgr \
        ostree skopeo podman which \
        nano vim git github-cli wget curl htop btop jq sbctl \
        man-db man-pages bash-completion \
        usbutils pciutils inetutils bolt \
        openssh rsync zip unzip p7zip \
        exfatprogs btrfs-progs udisks2 wireguard-tools iperf3

RUN moduledir=$(find /usr/lib/modules -mindepth 1 -maxdepth 1 -type d) && \
    kernel=$(cat ${moduledir}/pkgbase) && \
    cat /boot/*-ucode.img /boot/initramfs-${kernel}.img > ${moduledir}/initramfs.img

# ── Sudoers and subuid/subgid for rootless containers ──
RUN echo "%wheel ALL=(ALL) ALL" > /etc/sudoers.d/10-wheel && \
    echo "%wheel ALL=NOPASSWD: /usr/bin/ostree" > /etc/sudoers.d/20-ostree && \
    { \
        echo "Cmnd_Alias YORHA = /usr/bin/yorha \"\",/usr/bin/yorha compose *,/usr/bin/yorha upgrade *,/usr/bin/yorha deployment *"; \
        echo "Defaults!YORHA env_keep +=YORHA_BASE_PATH"; \
        echo "Defaults!YORHA env_keep +=YORHA_LIBEXEC_PATH"; \
        echo "Defaults!YORHA env_keep +=OSTREE_STATEROOT"; \
        echo "Defaults!YORHA env_keep +=OSTREE_BRANCH"; \
        echo "%wheel ALL=NOPASSWD: YORHA"; \
    } > /etc/sudoers.d/30-yorha && \
    echo "root:1000000:65536" >> /etc/subuid && \
    echo "root:1000000:65536" >> /etc/subgid

# ── Default kernel arguments ──
RUN mkdir -p /etc/cache22 && \
    { \
        echo "quiet"; \
        echo "loglevel=3"; \
        echo "systemd.show_status=auto"; \
        echo "rd.udev.log_level=3"; \
    } > /etc/cache22/kargs

# ── Yorha tooling — available to all images built on this base ──
COPY yorha /usr/bin/yorha
COPY base /usr/share/cache22/base
COPY libexec /usr/libexec
COPY scripts/c22-update /usr/bin/c22-update
COPY scripts/c22-setup-secureboot /usr/bin/c22-setup-secureboot

RUN mkdir -p /usr/share/cache22 && \
    sed -i "s|libexec|/usr/libexec|" /usr/bin/yorha && \
    sed -i "s|YORHA_BASE_PATH:-|YORHA_BASE_PATH:-/usr/share/cache22/|" \
        /usr/libexec/yorha-config && \
    chmod +x /usr/bin/c22-update \
              /usr/bin/c22-setup-secureboot
