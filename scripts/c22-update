#!/usr/bin/env bash
set -e

KARGS_FILE="/etc/cache22/kargs"

# ─────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${BLUE}==>${RESET} ${BOLD}$*${RESET}"; }
success() { echo -e "${GREEN}==>${RESET} ${BOLD}$*${RESET}"; }
warn()    { echo -e "${YELLOW}==>${RESET} $*"; }
error()   { echo -e "${RED}==>${RESET} ${BOLD}$*${RESET}" >&2; exit 1; }

require_root() {
    if [[ $EUID -ne 0 ]]; then
        error "Run with sudo"
    fi
}

# Build the image reference by reading the default values that the
# Containerfile baked into yorha-config via sed substitutions.
_cfg=/usr/libexec/yorha-config
_oci_registry=$(sed -n 's/export OCI_REGISTRY="${OCI_REGISTRY:-\(.*\)}"/\1/p' "$_cfg")
_gh_account=$(sed -n 's/export GH_ACCOUNT="${GH_ACCOUNT:-\(.*\)}"/\1/p' "$_cfg")
_gh_project=$(sed -n 's/export GH_PROJECT="${GH_PROJECT:-\(.*\)}"/\1/p' "$_cfg")
_default_base=$(sed -n 's/export DEFAULT_BASE="${DEFAULT_BASE:-\(.*\)}" #.*/\1/p' "$_cfg")
IMAGE="${_oci_registry}/${_gh_account}/${_gh_project}/${_default_base}:latest"

# ─────────────────────────────────────────────
# Shared helpers
# ─────────────────────────────────────────────

_cleanup_old_image() {
    local old_id="$1"
    if [[ -z "$old_id" ]]; then
        return
    fi
    local tags
    tags=$(podman inspect --format '{{.RepoTags}}' "$old_id" 2>/dev/null || true)
    if [[ -z "$tags" || "$tags" == "[]" ]]; then
        info "Removing previous image (${old_id:0:12})..."
        podman rmi -f "$old_id" 2>/dev/null || true
    fi
}

_cleanup_deployments() {
    local deployment_count
    deployment_count=$(ostree admin status | grep -c "^\*\? " 2>/dev/null || echo 0)
    if [[ "$deployment_count" -gt 2 ]]; then
        info "Pruning old OSTree deployments (keeping 2)..."
        ostree admin cleanup
    fi
}

_resign_secureboot() {
    if sbctl status 2>/dev/null | grep -q "Installed: ✓"; then
        info "Re-signing EFI binaries with sbctl..."
        sbctl sign-all
    fi
}

# ─────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────
cmd_system() {
    require_root

    local old_image_id
    old_image_id=$(podman inspect --format '{{.Id}}' "$IMAGE" 2>/dev/null || true)

    yorha upgrade remote

    _resign_secureboot
    _cleanup_old_image "$old_image_id"
    _cleanup_deployments

    success "Update complete. Reboot to use the new deployment."
    echo "    Run: sudo yorha deployment list — to see available deployments."
}

cmd_kargs() {
    require_root

    if [[ ! -f "$KARGS_FILE" ]]; then
        error "$KARGS_FILE not found. Cannot apply kernel arguments."
    fi

    info "Applying kernel arguments from $KARGS_FILE..."

    local kargs="root=LABEL=SYS_ROOT rw"
    while IFS= read -r karg; do
        [[ -n "$karg" ]] && kargs="$kargs $karg"
    done < "$KARGS_FILE"

    local karg_flags=""
    for karg in $kargs; do
        karg_flags="$karg_flags --append=$karg"
    done

    # shellcheck disable=SC2086
    ostree admin instutil set-kargs --sysroot=/sysroot $karg_flags

    success "Kernel arguments updated. Reboot to apply."
    echo ""
    echo "    Current arguments:"
    while IFS= read -r karg; do
        [[ -n "$karg" ]] && echo "      $karg"
    done < "$KARGS_FILE"
}

cmd_rebase() {
    require_root

    local new_image="${1:-}"
    if [[ -z "$new_image" ]]; then
        error "Usage: sudo c22-update rebase <image-url>"
    fi

    info "Rebasing system to $new_image..."
    warn "This will replace your current image source. The next reboot will"
    warn "use the new image. Your /etc and /var are preserved."
    echo ""
    read -r -p "Continue? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }

    local old_image_id
    old_image_id=$(podman inspect --format '{{.Id}}' "$IMAGE" 2>/dev/null || true)

    info "Pulling $new_image..."
    podman pull "$new_image"

    info "Deploying $new_image..."
    yorha upgrade remote "$new_image"

    _resign_secureboot
    _cleanup_old_image "$old_image_id"
    _cleanup_deployments

    success "Rebase complete. Reboot to use the new image."
    echo "    New image: $new_image"
}

# ─────────────────────────────────────────────
# Usage
# ─────────────────────────────────────────────
usage() {
    echo -e "
${BOLD}c22-update${RESET} — Cache22 update utility

${BOLD}Usage:${RESET}
  sudo c22-update <command> [options]

${BOLD}Commands:${RESET}
  system          Pull the latest image and deploy it as a new OSTree
                  deployment. The previous deployment is kept as a rollback
                  target. Reboot to use the new deployment.

  kargs           Apply the current contents of /etc/cache22/kargs to the
                  running deployment without doing a full system update.
                  Edit that file to add or remove kernel arguments, then
                  run this command. Reboot to apply.

  rebase <url>    Switch to a different image. Pulls the image at <url>,
                  deploys it, and makes it the new update source.
                  Your /etc and /var are preserved across the rebase.
                  Reboot to use the new image.

${BOLD}Examples:${RESET}
  sudo c22-update system
  sudo c22-update kargs

  # Add a kernel argument and apply it:
  echo \"i8042.reset=1\" | sudo tee -a /etc/cache22/kargs
  sudo c22-update kargs
  sudo reboot

  # Switch to a different flavor:
  sudo c22-update rebase ghcr.io/cmspam/cache22/cachyos-gnome:latest
"
    exit 0
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────
case "${1:-}" in
    system)  cmd_system ;;
    kargs)   cmd_kargs  ;;
    rebase)  cmd_rebase "${2:-}" ;;
    *)       usage      ;;
esac
